{
  "name": "opencode-flight-recorder",
  "version": "0.1.0",
"type": "module",
  "description": "OpenCode Flight Recorder — captures, structures, and stores all LLM interactions",
  "main": "dist/plugin/index.js",
  "exports": {
    ".": {
      "import": "./dist/plugin/index.js",
      "types": "./dist/plugin/index.js"
    }
  },
  "types": "dist/plugin/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "flight": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "flight": "node dist/cli/index.js"
  },
  "keywords": [
    "opencode",
    "plugin",
    "llm",
    "flight-recorder"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.9",
    "@opencode-ai/sdk": "^1.17.9"
  }
}
